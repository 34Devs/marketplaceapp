{% comment %}
  VendorHub - Shop by Vendor
  Displays a grid of marketplace vendors
  Data loaded via app proxy fetch
{% endcomment %}

<div class="vendorhub-shop-by-vendor" style="
  padding: {{ block.settings.padding }}px 0;
">
  <h2 style="
    text-align: {{ block.settings.heading_alignment }};
    font-size: {{ block.settings.heading_size }}px;
    margin-bottom: 24px;
    color: {{ block.settings.heading_color }};
  ">
    {{ block.settings.heading }}
  </h2>

  <div id="vendorhub-vendors-grid" style="
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax({{ block.settings.card_min_width }}px, 1fr));
    gap: {{ block.settings.gap }}px;
  ">
    <p style="text-align: center; color: #6d7175; grid-column: 1 / -1;">
      Loading vendors...
    </p>
  </div>
</div>

<script>
  (function() {
    fetch('/apps/vendorhub/api/storefront/vendors')
      .then(function(r) { return r.json(); })
      .then(function(data) {
        var grid = document.getElementById('vendorhub-vendors-grid');
        if (!data.vendors || data.vendors.length === 0) {
          grid.innerHTML = '<p style="text-align:center;color:#6d7175;grid-column:1/-1;">No vendors available yet.</p>';
          return;
        }
        grid.innerHTML = data.vendors.map(function(v) {
          return '<a href="/apps/vendorhub/vendor/' + v.slug + '" style="' +
            'display:block;border:1px solid {{ block.settings.card_border_color }};' +
            'border-radius:12px;padding:20px;text-decoration:none;' +
            'background:{{ block.settings.card_background }};transition:box-shadow 0.2s;' +
          '">' +
            '<div style="display:flex;align-items:center;gap:12px;margin-bottom:8px;">' +
              '<div style="width:40px;height:40px;border-radius:50%;background:{{ block.settings.avatar_color }};' +
                'display:flex;align-items:center;justify-content:center;color:white;font-weight:700;font-size:16px;">' +
                v.storeName.charAt(0) +
              '</div>' +
              '<div style="font-weight:600;color:{{ block.settings.card_text_color }};">' + v.storeName + '</div>' +
            '</div>' +
            (v.description ? '<p style="font-size:13px;color:{{ block.settings.card_label_color }};margin:0;' +
              'overflow:hidden;text-overflow:ellipsis;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;">' +
              v.description + '</p>' : '') +
            '<div style="margin-top:8px;font-size:12px;color:{{ block.settings.card_label_color }};">' +
              v.productCount + ' products' +
              (v.rating > 0 ? ' · ' + v.rating.toFixed(1) + '★' : '') +
            '</div>' +
          '</a>';
        }).join('');
      })
      .catch(function() {
        document.getElementById('vendorhub-vendors-grid').innerHTML =
          '<p style="text-align:center;color:#6d7175;grid-column:1/-1;">Unable to load vendors.</p>';
      });
  })();
</script>

{% schema %}
{
  "name": "Shop by Vendor",
  "target": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Shop by Vendor"
    },
    {
      "type": "select",
      "id": "heading_alignment",
      "label": "Heading Alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ],
      "default": "center"
    },
    {
      "type": "range",
      "id": "heading_size",
      "label": "Heading Size",
      "min": 18,
      "max": 40,
      "step": 2,
      "default": 24,
      "unit": "px"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading Color",
      "default": "#202223"
    },
    {
      "type": "range",
      "id": "card_min_width",
      "label": "Card Min Width",
      "min": 200,
      "max": 400,
      "step": 20,
      "default": 260,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "gap",
      "label": "Card Gap",
      "min": 8,
      "max": 32,
      "step": 4,
      "default": 16,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding",
      "label": "Section Padding",
      "min": 0,
      "max": 60,
      "step": 4,
      "default": 24,
      "unit": "px"
    },
    {
      "type": "color",
      "id": "card_background",
      "label": "Card Background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "card_border_color",
      "label": "Card Border",
      "default": "#e1e3e5"
    },
    {
      "type": "color",
      "id": "card_text_color",
      "label": "Card Text",
      "default": "#202223"
    },
    {
      "type": "color",
      "id": "card_label_color",
      "label": "Card Label",
      "default": "#6d7175"
    },
    {
      "type": "color",
      "id": "avatar_color",
      "label": "Avatar Color",
      "default": "#5c2dbc"
    }
  ]
}
{% endschema %}
